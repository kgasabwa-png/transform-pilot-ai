{
  "manifest_version": 3,
  "name": "Nyvlo",
  "version": "0.2.0",
  "description": "See today's promises, your reliability score, and capture commitments from any page.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://transform-pilot-ai.lovable.app/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icon.png", "128": "icon.png" }
  },
  "icons": { "48": "icon.png", "128": "icon.png" }
}

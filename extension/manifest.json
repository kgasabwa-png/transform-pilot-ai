{
  "manifest_version": 3,
  "name": "Nyvlo",
  "version": "0.1.0",
  "description": "See today's promises and your reliability score from your browser toolbar.",
  "permissions": ["storage"],
  "host_permissions": ["https://transform-pilot-ai.lovable.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icon.png", "128": "icon.png" }
  },
  "icons": { "48": "icon.png", "128": "icon.png" }
}
